# Google OAuth & APIs
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_ANALYTICS_PROPERTY_ID=your_ga4_property_id
GOOGLE_ANALYTICS_MEASUREMENT_ID=your_ga4_measurement_id
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://yoursite.com

# Service Account for API Access (if using service account instead of OAuth)
GOOGLE_SERVICE_ACCOUNT_EMAIL=analyst@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
GOOGLE_PROJECT_ID=your-google-project-id

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/analyst_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=analyst_db

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_ORG_ID=org-xxxxx

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=debug

# Scheduled Jobs
ENABLE_DAILY_SYNC=true
DAILY_SYNC_TIME=06:00
TIMEZONE=America/New_York

# Optional: Data Sync Service
DATA_SYNC_BATCH_SIZE=1000
DATA_SYNC_MAX_RETRIES=3
DATA_SYNC_TIMEOUT_MS=300000
